# Supabase (public — safe to expose)
SUPABASE_PROJECT_ID="your-project-id"
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"

# Supabase (SECRET — server only, NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Encryption key for stored passwords (AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRED_ENCRYPTION_KEY="your-32-byte-hex-key"

# HMAC secret for client access tokens (30min TTL)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ACCESS_TOKEN_SECRET="your-hmac-secret"
